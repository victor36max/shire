# =============================================================
# Shire — Environment Variables
# Copy this file to .env and fill in values for local dev
# =============================================================

# --- Required in production ---
DATABASE_URL=ecto://postgres:postgres@localhost/shire
SECRET_KEY_BASE=generate_with_mix_phx_gen_secret
SPRITES_TOKEN=your_sprites_api_token_here
SPRITE_VM_NAME=your-sprite-vm-name

# --- Server config ---
PHX_HOST=localhost
PORT=4000
PHX_SERVER=true

# --- Optional ---
POOL_SIZE=10
ECTO_IPV6=false
DNS_CLUSTER_QUERY=
