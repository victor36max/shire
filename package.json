{
  "name": "shire",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "shire": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "dev:frontend": "vite --config src/frontend/vite.config.ts",
    "build:frontend": "vite build --config src/frontend/vite.config.ts",
    "build": "bun run build:frontend",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bunx drizzle-kit migrate",
    "db:studio": "bunx drizzle-kit studio",
    "catalog:sync": "bun run src/scripts/catalog-sync.ts",
    "test": "bun test src/services src/runtime src/routes src/scripts",
    "test:frontend": "bunx vitest run --config src/frontend/vite.config.ts",
    "test:all": "bun run test && bun run test:frontend",
    "test:watch": "bun test --watch src/",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write 'src/**/*.{ts,tsx}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx}'",
    "typecheck": "tsc --noEmit",
    "typecheck:frontend": "tsc --noEmit --project src/frontend/tsconfig.json"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.85",
    "@fontsource-variable/dm-sans": "^5.2.8",
    "@hono/zod-validator": "^0.7.6",
    "@mariozechner/pi-ai": "^0.63.1",
    "@mariozechner/pi-coding-agent": "^0.63.1",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.39.0",
    "hono": "^4.7.0",
    "js-yaml": "^4.1.0",
    "lucide-react": "^0.577.0",
    "node-schedule": "^2.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.2.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node-schedule": "^2.1.7",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitejs/plugin-react": "^6.0.1",
    "drizzle-kit": "^0.30.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jsdom": "^29.0.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.7.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  }
}
